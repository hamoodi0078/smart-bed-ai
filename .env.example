# ============================================================================
# Danah Smart Bed — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.
# ============================================================================

# ---------------------------------------------------------------------------
# Core web / app
# ---------------------------------------------------------------------------
WEB_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
WEB_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
APP_BASE_URL=http://127.0.0.1:8000
APP_BACKEND_BASE_URL=http://127.0.0.1:8000
# Set to your public hostname in production to prevent Host-header spoofing.
# Example: SERVER_HOSTNAME=api.danah.io
SERVER_HOSTNAME=

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# REQUIRED — must be 32+ chars, not in the unsafe defaults list.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# The app WILL NOT START without a valid SECRET_KEY.
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Field-level data encryption (health & sleep data at rest)
# ---------------------------------------------------------------------------
# REQUIRED for encrypted database columns.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Sentry — error tracking + performance monitoring
# ---------------------------------------------------------------------------
# Leave SENTRY_DSN blank to disable Sentry entirely.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Optional: pin a release string (e.g. git SHA) for source-map / diff views
SENTRY_RELEASE=
# Fraction of transactions to send to Sentry for performance monitoring (0.0–1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
# Fraction of sampled transactions to also profile (0.0–1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# OpenTelemetry tracing
# ---------------------------------------------------------------------------
# Set to 'none' to disable, 'console' for local debugging, 'otlp' (default) for Jaeger/OTEL Collector
OTEL_TRACES_EXPORTER=none
OTEL_SERVICE_NAME=danah-smart-bed
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
ARQ_REDIS_URL=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Fitbit
# ---------------------------------------------------------------------------
# Create an app at dev.fitbit.com → set OAuth2 Application Type to "Personal"
# Redirect URI must match FITBIT_REDIRECT_URI below
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://127.0.0.1:8000/v1/fitbit/callback

# ---------------------------------------------------------------------------
# Garmin Connect
# ---------------------------------------------------------------------------
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Optional: path to a directory where garminconnect stores session tokens
# (avoids re-authentication on every restart)
GARMIN_TOKENSTORE_PATH=runtime_data/garmin_tokens

# ---------------------------------------------------------------------------
# Google Calendar API
# ---------------------------------------------------------------------------
# Create an OAuth2 client in Google Cloud Console → APIs & Services → Credentials
# Enable the "Google Calendar API" for the project
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# OpenWeatherMap (pyowm)
# ---------------------------------------------------------------------------
# Leave blank to use the free open-meteo.com fallback (no key required)
OPENWEATHERMAP_API_KEY=

# ---------------------------------------------------------------------------
# Firebase / FCM
# ---------------------------------------------------------------------------
# Option 1: path to your service account JSON file
FIREBASE_CREDENTIALS_PATH=
# Option 2: inline service account JSON (overrides path if set)
FIREBASE_CREDENTIALS_JSON=

# ---------------------------------------------------------------------------
# Runtime storage
# ---------------------------------------------------------------------------
RUNTIME_DATA_DIR=runtime_data
SUBSCRIPTION_DB_PATH=runtime_data/subscription_db.json
USER_PROFILE_PATH=runtime_data/user_profile.json
LONG_TERM_MEMORY_PATH=runtime_data/long_term_memory.json
ALLOW_INSECURE_REPO_DATA_PATHS=0

# ---------------------------------------------------------------------------
# Voice / AI — Deepgram
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_API_KEY=
DEEPGRAM_VOICE_AGENT_MODEL=voice-agent-conversational
DEEPGRAM_VOICE_AGENT_URL=https://agent.deepgram.com/v1/agent/converse
DEEPGRAM_STT_MODEL=nova-2
STT_MODE=api
STT_REQUIRE_API_STREAM=0
STT_LOCAL_MODEL_SIZE=small
STT_LOCAL_DEVICE=cpu
STT_LOCAL_COMPUTE_TYPE=int8
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_TTS_VOICE=aura-2-thalia-en
DEEPGRAM_TTS_VOICE_THERAPIST=aura-2-thalia-en
DEEPGRAM_TTS_VOICE_COACH=aura-2-orion-en
DEEPGRAM_TTS_VOICE_GUIDE=aura-2-asteria-en
AI_TIMEOUT_SECONDS=20
CHAT_QUICK_TIMEOUT_SECONDS=4
CHAT_TOTAL_TIMEOUT_SECONDS=10
CHAT_MAX_RESPONSE_TOKENS=120
CACHE_TTL_SECONDS=86400
SMART_BED_LANGUAGE=auto
SMART_BED_API_FIRST=1

# ---------------------------------------------------------------------------
# Hugging Face — required for pyannote.audio speaker diarization
# ---------------------------------------------------------------------------
# 1) Create account at huggingface.co and generate a token (Settings > Access Tokens)
# 2) Accept the model licence at huggingface.co/pyannote/speaker-diarization-3.1
# 3) Paste your token below
HF_TOKEN=

# ---------------------------------------------------------------------------
# Voice / AI — LiteLLM universal router
# ---------------------------------------------------------------------------
# Route to any provider with a single model string: "anthropic/claude-opus-4-7",
# "gpt-4o", "gemini/gemini-1.5-pro", "ollama/llama3", etc.
# litellm reads the matching API key from the provider-specific var below.
LITELLM_DEFAULT_MODEL=anthropic/claude-opus-4-7

# ---------------------------------------------------------------------------
# Voice / AI — Anthropic / Claude (direct fallback when litellm is absent)
# ---------------------------------------------------------------------------
# 1) Create account at console.anthropic.com and generate an API key
# 2) Paste your key below — used by AnthropicConversationEngine and as litellm source
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Voice / AI — OpenAI (optional direct GPT route)
# ---------------------------------------------------------------------------
# 1) set USE_OPENAI_DIRECT=1
# 2) provide OPENAI_API_KEY from your OpenAI API account
# 3) keep OPENAI_CHAT_MODEL on a known model like gpt-4o-mini
USE_BACKEND_AI_PROXY=1
USE_OPENAI_DIRECT=0
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Wake word / automation
# ---------------------------------------------------------------------------
LOCAL_MUSIC_DIR=local_music
WAKE_WORD_MODE=keyboard
WAKE_WORD_PHRASE=hey smart bed
WAKE_WORD_ENFORCE_LOCAL=1
WAKE_WORD_MIC_INDEX=-1
WAKE_WORD_TIMEOUT_SECONDS=3
WAKE_WORD_PHRASE_LIMIT_SECONDS=0
WAKE_WORD_BARGE_IN_TIMEOUT_SECONDS=1
WAKE_WORD_BARGE_IN_PHRASE_LIMIT_SECONDS=0
QUIET_HOURS_DEFAULT_WINDOW=22:00-07:00
QUIET_HOURS_OVERRIDE_MAX_MINUTES=120
VOICE_CIRCUIT_FAILURE_THRESHOLD=3
VOICE_CIRCUIT_BACKOFF_BASE_SECONDS=3
VOICE_CIRCUIT_BACKOFF_MAX_SECONDS=60
VOICE_CIRCUIT_RESET_SIGNAL_PATH=runtime_data/voice_circuit_reset_signal.json

# ---------------------------------------------------------------------------
# Smart Home Device Control
# ---------------------------------------------------------------------------
# Philips Hue
HUE_BRIDGE_IP=
HUE_USERNAME=
# TP-Link Kasa (comma-separated IPs, or leave empty to auto-discover)
KASA_DEVICE_IPS=
# Xiaomi Mi (miio)
MIIO_DEVICE_IP=
MIIO_DEVICE_TOKEN=
MIIO_DEVICE_TYPE=light
# Apple TV (use `atvremote scan` to find the identifier)
ATV_IDENTIFIER=
# Chromecast (friendly name, or leave empty to use first found)
CHROMECAST_NAME=
# Tuya Cloud API (get credentials from iot.tuya.com → Cloud → Project)
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
# Comma-separated Tuya device IDs to control
TUYA_DEVICE_IDS=
# Region: us | eu | cn | in  (default: eu)
TUYA_REGION=eu
# Astral — location for real sunrise/sunset (used by CircadianEngine)
CIRCADIAN_LATITUDE=
CIRCADIAN_LONGITUDE=
CIRCADIAN_TIMEZONE=Asia/Kuwait

# ---------------------------------------------------------------------------
# Sensors
# ---------------------------------------------------------------------------
ENABLE_SENSOR_BRIDGE=1
SENSOR_PRESSURE_ENABLED=0
SENSOR_MOTION_ENABLED=0
SENSOR_PRESSURE_PIN=-1
SENSOR_MOTION_PIN=-1
SENSOR_PRESSURE_PULL_UP=1
SENSOR_MOTION_PULL_UP=0
SENSOR_PRESSURE_ACTIVE_LOW=1
SENSOR_MOTION_ACTIVE_LOW=0
SENSOR_POLL_INTERVAL_SECONDS=0.2
# AM2301A (DHT22) temperature & humidity sensor
SENSOR_TEMPERATURE_ENABLED=0
SENSOR_TEMPERATURE_PIN=4
SENSOR_TEMPERATURE_POLL_INTERVAL_SECONDS=5.0
# MAX30102 heart-rate & SpO2 sensor (I2C — enable I2C via raspi-config)
SENSOR_HEART_RATE_ENABLED=0
SENSOR_HEART_RATE_SAMPLE_COUNT=100
SENSOR_HEART_RATE_POLL_INTERVAL_SECONDS=5.0
AEC_MIN_CONFIDENCE_WHEN_PLAYING=0.72

# ---------------------------------------------------------------------------
# Spotify
# ---------------------------------------------------------------------------
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_DEVICE_ID=
SPOTIFY_DEFAULT_PLAYLIST_URI=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_SCOPES=user-read-playback-state user-modify-playback-state user-read-currently-playing user-read-email user-read-private
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/v1/mobile/spotify/callback

# ---------------------------------------------------------------------------
# Mobile OTP delivery (set TWILIO_* or webhook fields for real SMS delivery)
# ---------------------------------------------------------------------------
MOBILE_OTP_DELIVERY_MODE=auto
MOBILE_OTP_DEBUG=0
# NEVER set to 1 in production — bypasses real OTP delivery and accepts any code
MOBILE_OTP_SECRET=
MOBILE_OTP_DELIVERY_TIMEOUT_SECONDS=15
MOBILE_OTP_SMS_TEMPLATE=Danah verification code: {code}. It expires in {minutes} minutes.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
MOBILE_OTP_WEBHOOK_URL=
MOBILE_OTP_WEBHOOK_BEARER=

# ---------------------------------------------------------------------------
# Mobile social identity verification
# ---------------------------------------------------------------------------
MOBILE_SOCIAL_ALLOW_UNVERIFIED=0
MOBILE_SOCIAL_TIMEOUT_SECONDS=15
MOBILE_SOCIAL_GOOGLE_CLIENT_ID=
MOBILE_SOCIAL_FACEBOOK_APP_ID=
MOBILE_SOCIAL_FACEBOOK_APP_SECRET=
MOBILE_SOCIAL_APPLE_CLIENT_ID=
MOBILE_SOCIAL_APPLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Mobile bed provisioning controls
# ---------------------------------------------------------------------------
MOBILE_PAIRING_REQUIRE_CLAIM_TOKEN=1
MOBILE_PAIRING_ALLOW_AUTO_REGISTER=0

# ---------------------------------------------------------------------------
# Billing — PayPal
# ---------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=
PAYPAL_BRAND_NAME=Danah Smart Bed
PAYPAL_CURRENCY_CODE=USD
PAYPAL_TIMEOUT_SECONDS=20
PAYPAL_WEBHOOK_MAX_AGE_SECONDS=600
PAYPAL_WEBHOOK_RECEIPT_TTL_SECONDS=86400
PAYPAL_STANDARD_MONTHLY_PLAN_ID=
PAYPAL_STANDARD_YEARLY_PLAN_ID=
PAYPAL_PRO_MONTHLY_PLAN_ID=
PAYPAL_PRO_YEARLY_PLAN_ID=

# ---------------------------------------------------------------------------
# Device
# ---------------------------------------------------------------------------
BED_DEVICE_ID=
BED_FIRMWARE_VERSION=1.0.0
LED_HARDWARE_ENABLED=0
LED_BACKEND=auto
LED_FREQUENCY_HZ=800000
LED_USER_DMA_CHANNEL=10
LED_STATE_DMA_CHANNEL=11
LED_INVERT_SIGNAL=0
LED_MAX_BRIGHTNESS=255
LED_ANIMATION_FPS=20
USER_STRIP_PIN=18
STATE_STRIP_PIN=13
USER_STRIP_LED_COUNT=120
STATE_STRIP_LED_COUNT=60

# ---------------------------------------------------------------------------
# Database (PostgreSQL recommended for production)
# ---------------------------------------------------------------------------
# REQUIRED when running with docker-compose — must also be set in .env
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://user:password@localhost:5432/danah
# Required in production — app will refuse to start if this is empty

# ---------------------------------------------------------------------------
# AWS (S3 + SES)
# ---------------------------------------------------------------------------
# Leave blank to use the instance IAM role / default credential chain
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3 — bucket for storing generated PDF reports and audio recordings
AWS_S3_BUCKET=
AWS_S3_REPORTS_PREFIX=reports/
AWS_S3_PRESIGNED_URL_EXPIRY_SECONDS=3600
# SES — transactional email (must be a SES-verified address)
AWS_SES_FROM_EMAIL=
AWS_SES_FROM_NAME=Danah Smart Bed

# ---------------------------------------------------------------------------
# Email (SendGrid)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
EMAIL_FROM=

# ---------------------------------------------------------------------------
# Islamic Mode / Prayer Times
# ---------------------------------------------------------------------------
# Location for prayer times (use either city/country OR latitude/longitude)
ISLAMIC_PRAYER_CITY=Kuwait City
ISLAMIC_PRAYER_COUNTRY=Kuwait
ISLAMIC_PRAYER_LATITUDE=
ISLAMIC_PRAYER_LONGITUDE=
# Calculation method: 1=MWL, 2=ISNA, 3=Egypt, 4=Makkah, 5=Karachi, 8=Kuwait, etc.
# See: https://aladhan.com/prayer-times-api#GetCalendarByCitys
ISLAMIC_PRAYER_METHOD=8
ISLAMIC_PRAYER_TIMEOUT_SECONDS=12
ISLAMIC_PRAYER_CACHE_PATH=runtime_data/prayer_times_cache.json
# Auto-detect location from IP (requires internet)
ISLAMIC_PRAYER_AUTO_LOCATION=0

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_GENERAL_PER_MINUTE=60

# ---------------------------------------------------------------------------
# WhatsApp (Facebook Graph API)
# ---------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=
