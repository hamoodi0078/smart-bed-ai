[Unit]
Description=Smart Bed web runtime API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/smart-bed
EnvironmentFile=/opt/smart-bed/.env
ExecStart=/opt/smart-bed/.venv/bin/python -m uvicorn web_server:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

