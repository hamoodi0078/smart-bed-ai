[Unit]
Description=Smart Bed voice runtime
After=network-online.target bluetooth.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
SupplementaryGroups=audio gpio
WorkingDirectory=/opt/smart-bed
EnvironmentFile=/opt/smart-bed/.env
ExecStart=/opt/smart-bed/.venv/bin/python /opt/smart-bed/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

